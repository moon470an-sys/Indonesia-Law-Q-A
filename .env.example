# === Anthropic API ===
# https://console.anthropic.com/settings/keys 에서 발급받은 키를 입력하세요.
# 채팅창에 한 번이라도 노출된 키는 즉시 폐기 후 재발급해서 여기에만 보관합니다.
ANTHROPIC_API_KEY=sk-ant-여기에_새로_발급한_키_입력

# === GitHub Pages 프론트엔드 ↔ 로컬 백엔드 인증 ===
# 프론트엔드(브라우저)가 X-Api-Token 헤더로 보내는 공유 비밀.
# 아무 문자열이나 길게 만드세요. 비워두면 인증을 건너뜁니다(로컬 테스트만).
# PowerShell 에서 무작위 토큰 만드는 예:
#   [Convert]::ToBase64String((1..32 | %{ Get-Random -Max 256 } | %{ [byte]$_ }))
CLIENT_API_TOKEN=

# === CORS 허용 오리진 (콤마 구분) ===
ALLOWED_ORIGINS=https://moon470an-sys.github.io,http://localhost:8501,http://127.0.0.1:8501

# === 데이터/캐시 위치 (옵션 - 기본값 사용 시 비워두세요) ===
# RAG_SOURCE_DIR=D:\인도네시아 법령 원문\헌법
# RAG_CHROMA_DIR=D:\rag_data\chroma_db
# RAG_MODEL_CACHE=D:\hf_cache

# === ChromaDB 클라이언트 모드 ===
# http      : 별도 `chroma run` 서버 프로세스에 HTTP로 접속 (권장, 재시작 무중단).
# persistent: 같은 프로세스에서 sqlite + HNSW 직접 매핑 (fallback).
# 마이그레이션: scripts\install_chroma_service.bat 로 ChromaDB를 서비스화한 뒤 http 모드로 전환.
RAG_CHROMA_MODE=http
RAG_CHROMA_HOST=127.0.0.1
RAG_CHROMA_PORT=8001
# RAG_CHROMA_PATH=D:\rag_data\chroma_db   # persistent 모드에서만 사용. 기본 RAG_CHROMA_DIR 호환.
